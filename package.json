{
  "name": "CAP2DSP",
  "version": "1.0.0",
  "description": "A simple CAP project deployed to a shared HDI container CAP2DSP.",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "mbt": "^1",
    "@sap/dev-cap-tools": "^1.31.0",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "build": "cds build --production",
    "deploy": "mbt build && cf deploy mta_archives/CAP2DSP_1.0.0.mtar",
    "watch-cap2dsp": "cds watch --open dspstewardship.cap2dsp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana",
        "model": [
          "srv",
          "db"
        ],
        "credentials": {
          "service": "CAP2DSP"
        }
      },
      "auth": "mocked"
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/cap2dsp"
  ]
}
