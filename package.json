{
  "name": "tr-fi-cap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "cds run",
    "build": "cds build --production"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.8.5"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.8.3"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      }
    },
    "build": {
      "target": "gen",
      "tasks": [
        {
          "src": "db",
          "for": "hana"
        },
        {
          "src": "srv",
          "for": "nodejs"
        }
      ]
    }
  }
}
